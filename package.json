{
  "name": "puzzle-generator",
  "version": "0.5.1",
  "description": "Browser application for generating jigsaw puzzles",
  "author": "Barry Stump <weevilgenius@users.noreply.github.com>",
  "homepage": "https://github.com/weevilgenius/puzzle-generator#readme",
  "repository": "github:weevilgenius/puzzle-generator",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "tsc && ANALYZE=1 vite build",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/bezier-js": "^4.1.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/mithril": "^2.2.8",
    "@types/node": "^24.12.0",
    "@types/poisson-disk-sampling": "^2.2.4",
    "@types/svg-arc-to-cubic-bezier": "^3.2.3",
    "@typescript-eslint/utils": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.7",
    "jiti": "^2.6.1",
    "lit": "^3.3.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sinon": "^21.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.4.0",
