{
  "name": "puzzle-generator",
  "version": "0.5.1",
  "description": "Browser application for generating jigsaw puzzles",
  "author": "Barry Stump <weevilgenius@users.noreply.github.com>",
  "homepage": "https://github.com/weevilgenius/puzzle-generator#readme",
  "repository": "github:weevilgenius/puzzle-generator",
  "license": "MIT",
  "scripts": {
    "postinstall": "playwright install chromium",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "tsc && ANALYZE=1 vite build",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "node scripts/screenshot.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/bezier-js": "^4.1.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/mithril": "^2.2.8",
    "@types/node": "^26.1.1",
    "@types/poisson-disk-sampling": "^2.2.4",
    "@types/svg-arc-to-cubic-bezier": "^3.2.3",
    "@typescript-eslint/utils": "^8.64.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "lit": "^3.3.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sinon": "^22.0.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.10.0",
    "bezier-js": "^6.1.4",
    "d3-delaunay": "^6.0.4",
    "martinez-polygon-clipping": "^0.8.1",
    "mithril": "^2.3.8",
    "paper": "^0.12.18",
    "poisson-disk-sampling": "^2.3.1",
    "svg-arc-to-cubic-bezier": "^3.2.0"
  }
}
