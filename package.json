{
  "name": "puzzle-generator",
  "version": "0.5.1",
  "description": "Browser application for generating jigsaw puzzles",
  "author": "Barry Stump <weevilgenius@users.noreply.github.com>",
  "homepage": "https://github.com/weevilgenius/puzzle-generator#readme",
  "repository": "github:weevilgenius/puzzle-generator",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "tsc && ANALYZE=1 vite build",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/bezier-js": "^4.1.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/mithril": "^2.2.8",
    "@types/node": "^25.9.1",
    "@types/poisson-disk-sampling": "^2.2.4",
    "@types/svg-arc-to-cubic-bezier": "^3.2.3",
    "@typescript-eslint/utils": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "jiti": "^2.7.0",
    "lit": "^3.3.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.7.0",
    "bezier-js": "^6.1.4",
    "d3-delaunay": "^6.0.4",
