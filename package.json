{
  "name": "puzzle-generator",
  "version": "0.5.1",
  "description": "Browser application for generating jigsaw puzzles",
  "author": "Barry Stump <weevilgenius@users.noreply.github.com>",
  "homepage": "https://github.com/weevilgenius/puzzle-generator#readme",
  "repository": "github:weevilgenius/puzzle-generator",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "tsc && ANALYZE=1 vite build",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/bezier-js": "^4.1.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/mithril": "^2.2.8",
    "@types/node": "^24.12.4",
    "@types/poisson-disk-sampling": "^2.2.4",
    "@types/svg-arc-to-cubic-bezier": "^3.2.3",
    "@typescript-eslint/utils": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.7.0",
    "lit": "^3.3.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.7.0",
    "bezier-js": "^6.1.4",
